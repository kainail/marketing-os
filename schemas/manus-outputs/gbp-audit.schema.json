{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketing-os.internal/schemas/manus-outputs/gbp-audit.schema.json",
  "version": "1.0.0",
  "title": "Google Business Profile Audit",
  "description": "Output of gbp-optimization task. Written to logs/gbp-audit-log.json.",
  "type": "object",
  "required": ["last_updated", "month", "locations_audited", "locations_with_tracked_url", "locations_without_tracked_url", "locations_with_stale_posts", "total_unanswered_questions", "total_flags", "priority_flags", "gbp_health_score", "tracking_coverage_percent"],
  "additionalProperties": false,
  "properties": {
    "last_updated": { "type": "string", "format": "date-time" },
    "month": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "locations_audited": { "type": "integer", "minimum": 0 },
    "locations_with_tracked_url": { "type": "integer", "minimum": 0 },
    "locations_without_tracked_url": { "type": "integer", "minimum": 0 },
    "locations_with_stale_posts": { "type": "integer", "minimum": 0 },
    "total_unanswered_questions": { "type": "integer", "minimum": 0 },
    "total_flags": { "type": "integer", "minimum": 0 },
    "priority_flags": { "type": "integer", "minimum": 0 },
    "gbp_health_score": {
      "type": "string",
      "enum": ["strong", "needs-work", "critical"]
    },
    "tracking_coverage_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "locations_missing_tracking": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Names of locations without tracking redirect URL"
    },
    "stale_post_locations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Locations with no GBP post in 14+ days"
    },
    "recommendation_for_ahri": { "type": "string" }
  }
}
